rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Helper Functions ──────────────────────────────────────
    function isAuthenticated() { return request.auth != null; }
    // ZERO-READ Custom Claim check! No get() document reads required.
    function isAdmin() { 
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Schedules ─────────────────────────────────────────────
    match /schedules/{scheduleId} {
      // Students can save/update their own schedule! Fixes the permission error.
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (request.auth.uid == scheduleId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Map Data Bundling & Buildings ─────────────────────────
    match /mapData/campusBuildings {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /buildings/{buildingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      
      // Floors and rooms nested matching
      match /floors/{floorId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
        
        match /rooms/{roomId} {
           allow read: if isAuthenticated();
           allow write: if isAdmin();
        }
      }
      
      // Room Statuses
      match /roomStatuses/{floorId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // ── Notifications ─────────────────────────────────────────
    match /notifications/{notificationId} {
      // Users can only read their own notifications, Admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.uid || isAdmin());
      // Users can only update their own notifications' `read` status
      allow update: if isAuthenticated() && request.auth.uid == resource.data.uid && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }
    
    // ── Events & Feedback ─────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && (
        request.resource.data.uid == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }
  }
}